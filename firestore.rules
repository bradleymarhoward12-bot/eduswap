rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isChatParticipant() {
      return signedIn() && request.auth.uid in resource.data.participants;
    }

    function isParticipant(chatId) {
      return signedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }

    function hasNoLegacyTutorSubjectFields(data) {
      return !data.keys().hasAny(["subject", "subjects"]);
    }

    function tutorCourseLooksValid(course) {
      return course is map
        && course.keys().hasAll(["code", "title"])
        && course.code is string
        && course.title is string
        && (!course.keys().hasAny(["grade"]) || course.grade is string);
    }

    function tutorCoursesLookValid(data) {
      return data.courses is list
        && data.courses.size() > 0
        && tutorCourseLooksValid(data.courses[0]);
    }

    function listingImagesLookValid(data) {
      return data.images is list
        && data.images.size() > 0
        && data.images[0] is string
        && data.images[0].size() > 0;
    }

    function listingOwnerPayloadLooksValid(data) {
      return data.title is string
        && data.title.size() > 0
        && (!data.keys().hasAny(["description"]) || (data.description is string && data.description.size() >= 0))
        && data.price is number
        && data.price >= 0
        && data.category is string
        && data.category.size() > 0
        && data.condition is string
        && data.condition.size() > 0
        && data.sellerId is string
        && data.sellerId.size() > 0
        && data.sellerName is string
        && data.sellerName.size() > 0
        && data.imageUrl is string
        && data.imageUrl.size() > 0
        && (!data.keys().hasAny(["subcategory"]) || data.subcategory is string)
        && (!data.keys().hasAny(["courseCode"]) || data.courseCode is string)
        && (!data.keys().hasAny(["courseTitle"]) || data.courseTitle is string)
        && (!data.keys().hasAny(["relatedCourseCodes"]) || data.relatedCourseCodes is list)
        && (!data.keys().hasAny(["tags"]) || data.tags is list)
        && (!data.keys().hasAny(["status"]) || data.status in ["active", "sold", "inactive"])
        && (!data.keys().hasAny(["isAvailable"]) || data.isAvailable is bool);
    }

    function tutorSubjectFieldsUnchanged() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(["subject", "subjects"]);
    }

    match /users/{userId} {
      allow read, write: if isSelf(userId);
    }

    match /listings/{listingId} {
      allow read: if true;
      allow create: if signedIn()
        && request.auth.uid == request.resource.data.sellerId
        && request.resource.data.interestedCount == 0
        && listingOwnerPayloadLooksValid(request.resource.data);
      allow update: if signedIn() && (
        request.auth.uid == resource.data.sellerId
        && listingOwnerPayloadLooksValid(request.resource.data)
        || (
          request.auth.uid != resource.data.sellerId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["interestedCount", "savesCount", "likesCount", "interestedUsers", "latestInterestAt"])
          // Allow signed-in non-owners to adjust interest/save-related counters
          // Validate types and non-negative counts rather than enforcing exact arithmetic
          && request.resource.data.interestedCount is int
          && request.resource.data.interestedCount >= 0
          && (!request.resource.data.keys().hasAny(["savesCount"]) || request.resource.data.savesCount is int)
          && (!request.resource.data.keys().hasAny(["likesCount"]) || request.resource.data.likesCount is int)
          && (!request.resource.data.keys().hasAny(["interestedUsers"]) || request.resource.data.interestedUsers is list)
          && (!request.resource.data.keys().hasAny(["latestInterestAt"]) || request.resource.data.latestInterestAt is timestamp)
        )
      );
      allow delete: if signedIn() && request.auth.uid == resource.data.sellerId;
    }

    match /tutors/{tutorId} {
      allow read: if true;
      allow create: if signedIn()
        && request.auth.uid == request.resource.data.userId
        && hasNoLegacyTutorSubjectFields(request.resource.data)
        && tutorCoursesLookValid(request.resource.data);
      allow update: if signedIn()
        && (
          (
            request.auth.uid == resource.data.userId
            && tutorSubjectFieldsUnchanged()
            && tutorCoursesLookValid(request.resource.data)
          )
          || (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(["reviewCount", "updatedAt"])
            && request.resource.data.reviewCount == resource.data.reviewCount + 1
          )
        );
      allow delete: if signedIn() && request.auth.uid == resource.data.userId;

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if signedIn();
        allow update, delete: if false;
      }
    }

    match /chats/{chatId} {
      allow read: if isChatParticipant();
      allow create: if signedIn() && request.auth.uid in request.resource.data.participants;
      allow update: if isChatParticipant();
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isParticipant(chatId);
        allow create: if isParticipant(chatId) && request.resource.data.senderId == request.auth.uid;
        allow update: if isParticipant(chatId)
          && resource.data.type == "tutor_request"
          && request.resource.data.type == "tutor_request";
        allow delete: if false;
      }
    }

    match /tutorRequests/{requestId} {
      allow read: if signedIn()
        && (request.auth.uid == resource.data.tutorId || request.auth.uid == resource.data.studentId);
      allow create: if signedIn()
        && request.auth.uid == request.resource.data.studentId
        && request.resource.data.tutorId is string
        && request.resource.data.studentName is string
        && request.resource.data.courseCode is string
        && request.resource.data.courseTitle is string
        && request.resource.data.message is string
        && request.resource.data.status == "pending"
        && request.resource.data.chatId is string;
      allow update: if signedIn()
        && request.auth.uid == resource.data.tutorId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status", "updatedAt"])
        && request.resource.data.status in ["pending", "accepted", "rejected"];
      allow delete: if false;
    }

    match /notifications/{notificationId} {
      allow read, update, delete: if signedIn() && request.auth.uid == resource.data.userId;
      allow create: if signedIn()
        && request.resource.data.userId is string
        && request.resource.data.type in ["interest", "message", "chat"]
        && request.resource.data.title is string
        && request.resource.data.body is string
        && request.resource.data.relatedId is string
        && request.resource.data.isRead == false;
    }

    match /users/{userId}/notifications/{notificationId} {
      allow read, update, delete: if signedIn() && request.auth.uid == userId;
      allow create: if signedIn()
        && request.resource.data.type in ["interest", "message", "chat"]
        && request.resource.data.title is string
        && request.resource.data.body is string
        && request.resource.data.relatedId is string;
    }

    match /interests/{interestId} {
      allow create: if signedIn() && request.auth.uid == request.resource.data.userId;
      allow read, update, delete: if signedIn() && request.auth.uid == resource.data.userId;
    }

    match /savedItems/{savedId} {
      // One doc per user+item (deterministic id). Owners may create/read/delete their saved items.
      allow create: if signedIn()
        && request.auth.uid == request.resource.data.userId
        && request.resource.data.itemId is string
        && request.resource.data.type == "listing"
        && request.resource.data.createdAt is timestamp;

      allow read: if signedIn() && request.auth.uid == resource.data.userId;

      allow update: if signedIn()
        && request.auth.uid == resource.data.userId
        && request.resource.data.itemId == resource.data.itemId
        && request.resource.data.userId == resource.data.userId;

      allow delete: if signedIn() && request.auth.uid == resource.data.userId;
    }

    match /listingInterest/{interestId} {
      allow create: if signedIn()
        && request.auth.uid == request.resource.data.userId
        && request.resource.data.listingId is string
        && request.resource.data.sellerId is string
        && request.resource.data.type in ["save", "offer", "message", "view"]
        && request.resource.data.createdAt is timestamp;

      allow read: if signedIn() && (
        request.auth.uid == resource.data.userId
        || request.auth.uid == resource.data.sellerId
      );

      allow update: if signedIn() && (
        (
          request.auth.uid == resource.data.userId
          && request.resource.data.userId == resource.data.userId
          && request.resource.data.listingId == resource.data.listingId
          && request.resource.data.sellerId == resource.data.sellerId
          && request.resource.data.type == resource.data.type
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(["userId", "listingId", "sellerId", "type"])
        )
        || (
          request.auth.uid == resource.data.sellerId
          && resource.data.type == "offer"
          && request.resource.data.status in ["pending", "accepted", "rejected"]
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status"])
        )
      );

      allow delete: if signedIn() && request.auth.uid == resource.data.userId;
    }

    match /userActivity/{activityId} {
      allow create: if signedIn() && request.auth.uid == request.resource.data.userId;
      allow read: if signedIn() && (
        request.auth.uid == resource.data.userId
        || request.auth.uid == resource.data.viewedByUserId
      );
      allow update, delete: if signedIn() && request.auth.uid == resource.data.userId;
    }

    match /courseResources/{resourceId} {
      allow read: if true;
      allow create, update, delete: if false;
    }
  }
}
